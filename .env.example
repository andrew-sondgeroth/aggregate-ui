# API base URL (defaults to https://aggregateapi-production.up.railway.app if not set)
VITE_API_BASE_URL=http://localhost:8080

# Demo API key for live demo, explore, and search pages
# Register a new key: POST /api/v1/keys/register {"name":"...", "email":"..."}
# Keys use ak_ prefix format. FREE tier: 100 requests/day.
VITE_DEMO_API_KEY=ak_your-key-here
